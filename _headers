# Long-lived immutable cache for version-stamped static assets.
# HTML stays default (must-revalidate) so content updates propagate immediately.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable
